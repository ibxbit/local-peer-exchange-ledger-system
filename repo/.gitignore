# =============================================================================
# .gitignore — SkillShare Platform (Flask + Vanilla JS SPA)
# =============================================================================

# -----------------------------------------------------------------------------
# AI session data
# -----------------------------------------------------------------------------
.claude/
.cursor/
.aider*
.copilot/
*.ai-session
*.session.json

# -----------------------------------------------------------------------------
# Secrets, credentials, private keys
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.json
credentials.json

# Project-specific generated secrets (auto-created on first run)
instance/config.json

# -----------------------------------------------------------------------------
# Database files
# -----------------------------------------------------------------------------
instance/*.db
instance/*.db-shm
instance/*.db-wal
instance/*.sqlite
instance/*.sqlite3
*.db
*.sqlite
*.sqlite3
*.sql.gz
*.dump

# -----------------------------------------------------------------------------
# Generated reports (runtime output, not source)
# -----------------------------------------------------------------------------
instance/reports/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
pythonenv*/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Test / coverage artefacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.lcov
nosetests.xml
test-results/
junit*.xml

# Type-checking / linting caches
.mypy_cache/
.dmypy.json
.pyright/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node / JavaScript (if frontend tooling is added later)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
dist/
.next/
.nuxt/
.svelte-kit/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
log/

# -----------------------------------------------------------------------------
# OS / system files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.orig
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Misc machine-specific / temporary
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.pid
*.seed
.cache/
tmp/
temp/
